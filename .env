# Meta Graph API
META_ACCESS_TOKEN=your_page_or_user_access_token_here     #  Les tokens et IDs utilisés pour tester le projet ont été des informations personnelles.
META_APP_SECRET=your_app_secret_here                      # Ils ont été supprimés/masqués pour la sécurité avant de partager le projet.
META_APP_SECRET=your_app_secret_here                      # Le projet a été testé avec des API réelles et fonctionne correctement.


# IDs des comptes à collecter
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=social_media_collector

# Paramètres de collecte
DEFAULT_LIMIT=50
IMAGE_DOWNLOAD=true
LOG_LEVEL=INFO
